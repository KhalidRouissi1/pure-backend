# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pure_local_dev"

# Better Auth (use a random secret of at least 32 characters)
BETTER_AUTH_SECRET="replace-with-a-random-production-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000/api/auth"
AUTH_TRUSTED_ORIGINS="pure://"
AUTH_REQUIRE_EMAIL_VERIFICATION="false" # production must use true

# Resend email delivery (required when verification is enabled)
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Pure <auth@example.com>"

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Server
PORT=3000
NODE_ENV="development"

# Browser origins, comma-separated. Production must never use "*".
CORS_ORIGIN="http://localhost:19006"
